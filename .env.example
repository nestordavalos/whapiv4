# ============================================
# whapiv4 — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ---------- Database ----------
MYSQL_ENGINE=mariadb              # mariadb | mysql
MYSQL_VERSION=10.6
MYSQL_ROOT_PASSWORD=CHANGE_ME     # REQUIRED — strong password for DB root
MYSQL_DATABASE=whapi
MYSQL_PORT=3306
TZ=America/Fortaleza               # Timezone for MySQL container
DB_DIALECT=mariadb                # mariadb | mysql | postgres
DB_HOST=mysql                     # Docker service name or IP
DB_PORT=3306
DB_USER=root
DB_PASS=CHANGE_ME                 # Must match MYSQL_ROOT_PASSWORD
DB_NAME=whapi
DB_TIMEZONE=-03:00

# ---------- Authentication (REQUIRED) ----------
JWT_SECRET=CHANGE_ME              # REQUIRED — long random string (min 32 chars)
JWT_REFRESH_SECRET=CHANGE_ME      # REQUIRED — different long random string

# ---------- URLs ----------
BACKEND_URL=https://api.mydomain.com   # Public backend URL
FRONTEND_URL=https://myapp.mydomain.com # Public frontend URL (used for CORS)
PROXY_PORT=443                         # Port exposed by reverse proxy

# ---------- Ports ----------
BACKEND_PORT=8080                 # Host port → backend container
FRONTEND_PORT=80                  # Host port → frontend container
FRONTEND_SSL_PORT=443             # Host port → frontend HTTPS
PORT=3333                         # Internal backend listen port

# ---------- Nginx / SSL ----------
FRONTEND_SERVER_NAME=myapp.mydomain.com
BACKEND_SERVER_NAME=api.mydomain.com

# ---------- Node ----------
NODE_ENV=production               # production | development
TRUST_PROXY=1                     # Number of trusted proxies (1 = single nginx)

# ---------- Chrome / Puppeteer (WhatsApp Web) ----------
CHROME_ARGS=--no-sandbox --disable-setuid-sandbox

# ---------- WhatsApp Web.js ----------
WHATSAPP_INIT_TIMEOUT_MS=60000
WHATSAPP_MAX_RETRIES=3
WHATSAPP_MAX_RECONNECT_ATTEMPTS=5
WHATSAPP_RECONNECT_ON_DISCONNECT=true
WHATSAPP_HEALTH_CHECK_INTERVAL_MS=30000
WHATSAPP_CIRCUIT_BREAKER_ENABLED=true

# ---------- Rate Limiting ----------
RATE_LIMIT_GENERAL=5000           # Max requests per 15 min (general)
RATE_LIMIT_AUTH=5                 # Max login attempts per 15 min
RATE_LIMIT_API=300                # Max API requests per minute
RATE_LIMIT_MESSAGES=50            # Max messages per minute
RATE_LIMIT_CREATE=20              # Max create operations per minute

# ---------- Limits ----------
USER_LIMIT=                       # Max users (empty = unlimited)
CONNECTIONS_LIMIT=                # Max WhatsApp connections (empty = unlimited)
DEMO=false                        # Enable demo mode

# ---------- Storage (S3 / S3-Compatible) ----------
STORAGE_TYPE=local                # local | s3
STORAGE_LOCAL_DIRECTORY=public
STORAGE_FALLBACK_TO_LOCAL=true
STORAGE_DELETE_LOCAL_AFTER_UPLOAD=false
# S3 (required when STORAGE_TYPE=s3)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_ENDPOINT=              # Custom endpoint for MinIO/DigitalOcean Spaces
STORAGE_S3_FORCE_PATH_STYLE=false # true for MinIO
STORAGE_S3_PREFIX=
STORAGE_S3_PUBLIC_URL=            # Public CDN URL

# ---------- Monitoring ----------
SENTRY_DSN=                       # Sentry DSN for error tracking (optional)

# ---------- PM2 (Production) ----------
PM2_BACKEND=backend
PM2_FRONTEND=frontend

# ---------- Browserless (optional) ----------
MAX_CONCURRENT_SESSIONS=

# ---------- phpMyAdmin (optional) ----------
PMA_PORT=

# ---------- Misc ----------
SYNC_CREATE_CLOSED_FOR_READ=false