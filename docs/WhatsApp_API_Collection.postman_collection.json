              "raw": "{\n  \"mediaUrl\": \"https://example.com/image.jpg\",\n  \"body\": \"Esta imagen es de internet\",\n  \"filename\": \"imagen_descargada.jpg\",\n  \"quotedMsgId\": null\n}"
