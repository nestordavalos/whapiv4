{
  "info": {
    "name": "WhatsApp Integration API",
    "description": "Colección completa de la API de WhatsApp con soporte para multimedia (archivos, URL y base64)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "whatsapp-api"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{API_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "API_TOKEN",
      "value": "TU_TOKEN_AQUI",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "API Original (/api)",
      "item": [
        {
          "name": "Enviar Mensaje de Texto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"595991234567\",\n  \"body\": \"Hola, este es un mensaje de prueba\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/send",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "send"]
            }
          }
        },
        {
          "name": "Enviar Mensaje con Multimedia",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "number",
                  "value": "595991234567",
                  "type": "text"
                },
                {
                  "key": "body",
                  "value": "Mira esta imagen",
                  "type": "text"
                },
                {
                  "key": "medias",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{BASE_URL}}/api/send",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "send"]
            }
          }
        },
        {
          "name": "Listar Colas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/queue/list",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "queue", "list"]
            }
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Listar Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/v1/tickets?status=open&page=1&limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "tickets"],
              "query": [
                {
                  "key": "status",
                  "value": "open",
                  "description": "open, pending, closed"
                },
                {
                  "key": "whatsappId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "queueId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Obtener Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/v1/tickets/:ticketId",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "tickets", ":ticketId"],
              "variable": [
                {
                  "key": "ticketId",
                  "value": "123"
                }
              ]
            }
          }
        },
        {
          "name": "Crear Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"595991234567\",\n  \"whatsappId\": 2,\n  \"queueId\": 1,\n  \"userId\": null,\n  \"tagsId\": null\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/tickets",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "tickets"]
            }
          }
        },
        {
          "name": "Actualizar Ticket",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"closed\",\n  \"userId\": null,\n  \"queueId\": null\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/v1/tickets/:ticketId",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "v1", "tickets", ":ticketId"],
              "variable": [
                {
                  "key": "ticketId",
                  "value": "123"
                }
              ]
            }
          }
        }
      ]
    },
